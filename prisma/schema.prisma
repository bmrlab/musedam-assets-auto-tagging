generator client {
  provider = "prisma-client-js"
  output   = "../src/prisma/client"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

model Team {
  id   Int    @id @default(autoincrement())
  name String @default("") @db.VarChar(255)
  slug String @unique @db.VarChar(64)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  memberships       Membership[]
  assetTags         AssetTag[]
  assetObjects      AssetObject[]
  assetLogoTypes    AssetLogoType[]
  assetLogos        AssetLogo[]
  assetIpTypes      AssetIpType[]
  assetIps          AssetIp[]
  assetPersonTypes  AssetPersonType[]
  assetPersons      AssetPerson[]
  taggingQueueItems TaggingQueueItem[]
  taggingAuditItems TaggingAuditItem[]
  configs           TeamConfig[]
}

model User {
  id   Int    @id @default(autoincrement())
  name String @default("") @db.VarChar(255)
  slug String @unique @db.VarChar(64)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  memberships Membership[]
}

model Membership {
  id     Int  @id @default(autoincrement())
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId Int
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([userId, teamId])
}

model TeamConfig {
  id     Int    @id @default(autoincrement())
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id])
  key    String @db.VarChar(255)
  value  Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([teamId, key])
}

model AssetObject {
  id               Int    @id @default(autoincrement())
  teamId           Int
  team             Team   @relation(fields: [teamId], references: [id])
  slug             String @unique @db.VarChar(64)
  materializedPath String
  name             String
  description      String
  tags             Json   @default("[]") // string[]
  content          Json   @default("{}") // Record<string, string>
  extra            Json   @default("{}")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  taggingQueueItems TaggingQueueItem[]
  taggingAuditItems TaggingAuditItem[]
}

model AssetTag {
  id     Int  @id @default(autoincrement())
  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  name           String     @db.VarChar(100)
  slug           String?    @db.VarChar(64) // 新增以后还不存在 slug，和 musedam 同步以后会有
  level          Int        @default(1) // 层级: 1, 2, 3
  parentId       Int?
  parent         AssetTag?  @relation("TagHierarchy", fields: [parentId], references: [id])
  children       AssetTag[] @relation("TagHierarchy")
  sort           Int        @default(0) // 排序字段，数值越小排序越靠前
  taggingEnabled Boolean    @default(true) // 是否允许打标，默认开启
  extra          Json       @default("{}")

  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  taggingAuditItems TaggingAuditItem[]
  assetLogoTags     AssetLogoTag[]
  assetIpTags       AssetIpTag[]
  assetPersonTags   AssetPersonTag[]

  // ⚠️ migration.sql 里人工添加了一条 unique 索引，在 parentId 为空的时候，需要确保 teamId,name 唯一
  //    CREATE UNIQUE INDEX "AssetTag_teamId_name_key" ON "public"."AssetTag"("teamId", "name") WHERE "parentId" IS NULL;
  // Prisma 不支持这种类型的 unique 索引定义，智能人工添加
  //    目前这样不会导致 Prisma 判断 migration 和 schema 不同步，所以问题不大
  //    如果之后 squash migration，需要再次人工添加上面这个 sql
  @@unique([teamId, parentId, name])
}

enum AssetLogoProcessStatus {
  pending
  processing
  completed
  failed
}

model AssetLogoType {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)
  sort Int    @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  logos AssetLogo[]
}

model AssetLogo {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  slug            String                 @unique @default(cuid()) @db.VarChar(64)
  name            String                 @db.VarChar(255)
  logoTypeId      String?                @db.Uuid
  logoType        AssetLogoType?         @relation(fields: [logoTypeId], references: [id], onDelete: SetNull)
  logoTypeName    String                 @db.VarChar(100)
  status          AssetLogoProcessStatus @default(pending)
  processingError String?                @db.Text
  processedAt     DateTime?              @db.Timestamptz(6)
  enabled         Boolean                @default(true)
  notes           String                 @default("") @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  images AssetLogoImage[]
  tags   AssetLogoTag[]

  @@index([teamId, createdAt])
  @@index([teamId, status])
}

model AssetLogoImage {
  id          String    @id @default(uuid()) @db.Uuid
  assetLogoId String    @db.Uuid
  assetLogo   AssetLogo @relation(fields: [assetLogoId], references: [id], onDelete: Cascade)

  objectKey      String    @db.Text
  mimeType       String    @db.VarChar(255)
  size           Int
  sort           Int       @default(0)
  qdrantPointId  String?   @unique @db.VarChar(64)
  embeddingModel String?   @db.VarChar(128)
  embeddedAt     DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([assetLogoId, sort])
}

model AssetLogoTag {
  id          String    @id @default(uuid()) @db.Uuid
  assetLogoId String    @db.Uuid
  assetLogo   AssetLogo @relation(fields: [assetLogoId], references: [id], onDelete: Cascade)
  assetTagId  Int?
  assetTag    AssetTag? @relation(fields: [assetTagId], references: [id], onDelete: SetNull)

  tagPath Json @default("[]")
  sort    Int  @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assetLogoId, assetTagId])
  @@index([assetLogoId, sort])
}

enum AssetIpProcessStatus {
  pending
  processing
  completed
  failed
}

model AssetIpType {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)
  sort Int    @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  ips AssetIp[]
}

model AssetIp {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  slug            String               @unique @default(cuid()) @db.VarChar(64)
  name            String               @db.VarChar(255)
  ipTypeId        String?              @db.Uuid
  ipType          AssetIpType?         @relation(fields: [ipTypeId], references: [id], onDelete: SetNull)
  ipTypeName      String               @db.VarChar(100)
  description     String               @default("") @db.Text
  status          AssetIpProcessStatus @default(pending)
  processingError String?              @db.Text
  processedAt     DateTime?            @db.Timestamptz(6)
  enabled         Boolean              @default(true)
  notes           String               @default("") @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  images AssetIpImage[]
  tags   AssetIpTag[]

  @@index([teamId, createdAt])
  @@index([teamId, status])
}

model AssetIpImage {
  id        String  @id @default(uuid()) @db.Uuid
  assetIpId String  @db.Uuid
  assetIp   AssetIp @relation(fields: [assetIpId], references: [id], onDelete: Cascade)

  objectKey      String    @db.Text
  mimeType       String    @db.VarChar(255)
  size           Int
  sort           Int       @default(0)
  qdrantPointId  String?   @unique @db.VarChar(64)
  embeddingModel String?   @db.VarChar(128)
  embeddedAt     DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([assetIpId, sort])
}

model AssetIpTag {
  id         String    @id @default(uuid()) @db.Uuid
  assetIpId  String    @db.Uuid
  assetIp    AssetIp   @relation(fields: [assetIpId], references: [id], onDelete: Cascade)
  assetTagId Int?
  assetTag   AssetTag? @relation(fields: [assetTagId], references: [id], onDelete: SetNull)

  tagPath Json @default("[]")
  sort    Int  @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assetIpId, assetTagId])
  @@index([assetIpId, sort])
}

enum AssetPersonProcessStatus {
  pending
  processing
  completed
  failed
}

model AssetPersonType {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  name String @db.VarChar(100)
  sort Int    @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  persons AssetPerson[]
}

model AssetPerson {
  id     String @id @default(uuid()) @db.Uuid
  teamId Int
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  slug            String                   @unique @default(cuid()) @db.VarChar(64)
  name            String                   @db.VarChar(255)
  personTypeId    String?                  @db.Uuid
  personType      AssetPersonType?         @relation(fields: [personTypeId], references: [id], onDelete: SetNull)
  personTypeName  String                   @db.VarChar(100)
  status          AssetPersonProcessStatus @default(pending)
  processingError String?                  @db.Text
  processedAt     DateTime?                @db.Timestamptz(6)
  enabled         Boolean                  @default(true)
  notes           String                   @default("") @db.Text

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  images AssetPersonImage[]
  tags   AssetPersonTag[]

  @@index([teamId, createdAt])
  @@index([teamId, status])
}

model AssetPersonImage {
  id            String      @id @default(uuid()) @db.Uuid
  assetPersonId String      @db.Uuid
  assetPerson   AssetPerson @relation(fields: [assetPersonId], references: [id], onDelete: Cascade)

  objectKey      String    @db.Text
  mimeType       String    @db.VarChar(255)
  size           Int
  sort           Int       @default(0)
  qdrantPointId  String?   @unique @db.VarChar(64)
  embeddingModel String?   @db.VarChar(128)
  embeddedAt     DateTime? @db.Timestamptz(6)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([assetPersonId, sort])
}

model AssetPersonTag {
  id            String       @id @default(uuid()) @db.Uuid
  assetPersonId String       @db.Uuid
  assetPerson   AssetPerson  @relation(fields: [assetPersonId], references: [id], onDelete: Cascade)
  assetTagId    Int?
  assetTag      AssetTag?    @relation(fields: [assetTagId], references: [id], onDelete: SetNull)

  tagPath Json @default("[]")
  sort    Int  @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([assetPersonId, assetTagId])
  @@index([assetPersonId, sort])
}

enum TaggingQueueStatus {
  pending
  processing
  completed
  failed
}

enum TaggingTaskType {
  default
  test
  manual
  scheduled
}

model TaggingQueueItem {
  id            Int                @id @default(autoincrement())
  teamId        Int
  team          Team               @relation(fields: [teamId], references: [id])
  assetObjectId Int?
  assetObject   AssetObject?       @relation(fields: [assetObjectId], references: [id], onDelete: SetNull)
  status        TaggingQueueStatus
  taskType      TaggingTaskType    @default(default) // 任务类型：default=默认任务，test=测试任务
  startsAt      DateTime?          @db.Timestamptz(6)
  endsAt        DateTime?          @db.Timestamptz(6)
  result        Json               @default("{}")
  extra         Json               @default("{}")

  createdAt         DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(6)
  taggingAuditItems TaggingAuditItem[]

  @@index([teamId, status])
}

enum TaggingAuditStatus {
  pending
  approved
  rejected
}

model TaggingAuditItem {
  id            Int                @id @default(autoincrement())
  teamId        Int
  team          Team               @relation(fields: [teamId], references: [id])
  assetObjectId Int?
  assetObject   AssetObject?       @relation(fields: [assetObjectId], references: [id], onDelete: SetNull)
  status        TaggingAuditStatus
  score         Int
  tagPath       Json               @default("[]")
  leafTagId     Int?
  leafTag       AssetTag?          @relation(fields: [leafTagId], references: [id], onDelete: SetNull)
  queueItemId   Int?
  queueItem     TaggingQueueItem?  @relation(fields: [queueItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@index([teamId, status])
}
